<?xml version="1.0" encoding="utf-8"?>
<tabview width="275" height="275">
    <absolute id="tabModifiers" text="Modifiers" width="100%" height="100%">
        <label text="Event Name:" left="115" top="20"/>
        <textfield id="makeModName" left="185" top="18" width="80"/>
        <dropdown id="modList" left="150" top="50" width="110"/>
        <label text="Value:" left="105" top="85"/>
        <textfield id="makeModifierValue" left="150" top="83" width="80"/>
        <label id="howToTutorial_mod" text="" left="5" top="105" width="260" height="80"/>
        <button id="createEventButton_mod" text="Create Event" left="5" top="225" width="120"/>
        <button id="removeEventButton_mod" text="Remove Event" left="135" top="225" width="120"/>
    </absolute>

    <absolute text="Regular" width="100%" height="100%">
        <label text="Event Name:" left="115" top="20"/>
        <textfield id="makeRegularName" left="185" top="18" width="80"/>
        <dropdown id="RegularList" left="150" top="50" width="110"/>
        <label text="Value 1:" left="100" top="85"/>
        <textfield id="makeRegularValue" left="150" top="83" width="80"/>
        <label text="Value 2:" left="100" top="105"/>
        <textfield id="makeRegularTwoValue" left="150" top="103" width="80"/>
        <label id="howToTutorial_reg" text="" left="5" top="125" width="260" height="60"/>
        <button id="createEventButton_reg" text="Create Event" left="5" top="225" width="120"/>
        <button id="removeEventButton_reg" text="Remove Event" left="135" top="225" width="120"/>
    </absolute>

    <absolute text="Yours" width="100%" height="100%">
        <label text="Event Name:" left="115" top="20"/>
        <textfield id="makeYoursName" left="185" top="18" width="80"/>
        <dropdown id="yourList" left="150" top="50" width="110"/>
        <label text="Value 1:" left="100" top="85"/>
        <textfield id="makeYourValue" left="150" top="83" width="80"/>
        <label text="Value 2:" left="100" top="105"/>
        <textfield id="makeYourTwoValue" left="150" top="103" width="80"/>
        <label id="howToTutorial_your" text="" left="5" top="125" width="260" height="60"/>
        <button id="createEventButton_your" text="Create Event" left="5" top="225" width="120"/>
        <button id="removeEventButton_your" text="Remove Event" left="135" top="225" width="120"/>
    </absolute>

    <absolute text="Settings" width="100%" height="100%">
        <button id="copyButton_set" text="Copy Last" left="5" top="10" width="90"/>
        <number-stepper id="stepperCopy_set" left="110" top="12" min="-999" max="999" step="1"/>
        <button id="clearSectionButton_set" text="Clear Section" left="5" top="200" width="120"/>
        <button id="clearAllButton" text="Clear All" left="5" top="225" width="120"/>
    </absolute>
</tabview>
